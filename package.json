{
  "name": "night-train-watch-protocol",
  "version": "0.6.0",
  "private": false,
  "type": "module",
  "description": "夜行列車：守夜協定－依 GDD v1.1 製作的離線優先手機瀏覽器生存管理遊戲",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "capture:video": "node tools/capture-gameplay.mjs",
    "capture:motion": "node tools/capture-motion-qa.mjs",
    "capture:playability": "node tools/capture-playability-qa.mjs",
    "audit:buttons": "node tools/audit-buttons.mjs"
  },
  "keywords": [
    "game",
    "mobile-web",
    "pwa",
    "roguelite",
    "cozy-horror",
    "open-source"
  ],
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
